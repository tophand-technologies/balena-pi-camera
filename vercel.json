{
  "version": 2,
  "builds": [
    {
      "src": "spypoint-viewer.html",
      "use": "@vercel/static"
    },
    {
      "src": "supabase-browser-config.js",
      "use": "@vercel/static"
    },
    {
      "src": "threadgill.html",
      "use": "@vercel/static"
    },
    {
      "src": "threadgill-assets/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/threadgill/frigate.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/threadgill/media.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/threadgill/control.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/supabase/browser-config.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/supabase-browser-config.local.js",
      "dest": "/api/supabase/browser-config.js"
    },
    {
      "src": "/api/threadgill/control",
      "dest": "/api/threadgill/control.js"
    },
    {
      "src": "/api/threadgill/frigate",
      "dest": "/api/threadgill/frigate.js"
    },
    {
      "src": "/api/threadgill/media",
      "dest": "/api/threadgill/media.js"
    },
    {
      "src": "/threadgill/?",
      "dest": "/threadgill.html"
    },
    {
      "src": "/tophand/?",
      "dest": "/spypoint-viewer.html"
    },
    {
      "src": "/",
      "dest": "/spypoint-viewer.html"
    }
  ]
}
